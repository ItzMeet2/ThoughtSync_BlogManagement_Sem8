<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="BlogPU" transaction-type="JTA">
        <jta-data-source>java:app/BlogDS</jta-data-source>
        <class>com.mycompany.blogmanagement.entity.User</class>
        <class>com.mycompany.blogmanagement.entity.Role</class>
        <class>com.mycompany.blogmanagement.entity.Post</class>
        <class>com.mycompany.blogmanagement.entity.Category</class>
        <class>com.mycompany.blogmanagement.entity.Comment</class>
        <class>com.mycompany.blogmanagement.entity.Tag</class>
        <class>com.mycompany.blogmanagement.entity.PostLike</class>
        <class>com.mycompany.blogmanagement.entity.Report</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <property name="eclipselink.logging.level" value="WARNING"/>
            <property name="eclipselink.target-database" value="PostgreSQL"/>
            <!-- Explicit connection properties as fallback to prevent H2 in-memory DB generation -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/blogdb"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="zoro"/>
        </properties>
    </persistence-unit>
</persistence>
